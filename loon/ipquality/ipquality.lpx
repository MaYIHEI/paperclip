#!name=节点 IP 质量检测
#!desc=对齐 IP.Check.Place 口径检测节点 IP 类型、原始风险、风险标记及流媒体与 AI 可用性；手机单列排版，缺失数据不参与判断。
#!openUrl=
#!author=MaYIHEI[https://github.com/MaYIHEI]
#!homepage=https://github.com/MaYIHEI/paperclip/tree/testing/loon/ipquality
#!tag=节点,IP,风险,流媒体
#!date=2026-07-22

[Argument]
MaskIP = switch,false,tag=隐藏 IP,desc=隐藏报告中 IP 的后半段，适合截图分享
MediaTest = switch,true,tag=检测流媒体与 AI,desc=检测 TikTok、Disney+、Netflix、YouTube、Prime Video、Reddit 和 ChatGPT
MapNotification = switch,false,tag=地图通知,desc=完成后发送通知，点按后在 Apple 地图查看估算位置
ShowBasic = switch,true,tag=显示基础信息,desc=显示出口 IP、位置、ASN、组织和坐标
ShowEgressMatrix = switch,false,tag=显示出口分流,desc=按出口 IP 分组显示探针来源、ASN 和组织
ShowBGP = switch,false,tag=显示 BGP 信息,desc=查询 IPv4 前缀、Origin ASN、RPKI、PTR 和注册机构
ShowBGPPath = switch,false,tag=显示 BGP 路径线索,desc=分析 RIPE RIS 的 AS Path、可见性及 CN2、9929、163、169、CMI 等线路命中；不是实测回程
ShowChinaHttp = switch,false,tag=测试重点地区三网,desc=测试北京、上海、广东三网地区门户的 HTTP 连通耗时；不是省际 RTT
ShowInboundRoute = switch,false,tag=测试三网入站路径,desc=由 Globalping 中国电信、联通、移动探针向节点执行 traceroute；方向是入站而非回程
ShowEnhancedRoute = switch,false,tag=测试节点端真实回程,desc=调用用户自建的节点端诊断服务，展示真实回程及 ICMP、TCP 大包数据
EnhancedEndpoint = input,"",tag=节点端增强服务地址,desc=自有 VPS 的 HTTPS 诊断接口地址；不要附带查询参数
EnhancedToken = input,"",tag=节点端增强服务密钥,desc=可选 Bearer 密钥；仅发送给上方自建服务
ShowTypes = switch,false,tag=显示 IP 类型,desc=显示各数据库返回的使用类型与公司类型
ShowRiskScores = switch,true,tag=显示风险评分,desc=显示各数据库的原始风险评分
ShowRiskFactors = switch,false,tag=显示风险因素,desc=显示代理、VPN、Tor、机房等风险标记
ShowMedia = switch,true,tag=显示流媒体与 AI,desc=关闭时隐藏该分区并跳过相关请求
ShowRegionConsistency = switch,false,tag=显示地区一致性,desc=对比出口地区与各服务返回地区，不同只作提示
ShowDataStatus = switch,false,tag=显示数据状态,desc=显示成功来源、失败来源和出口一致性

[Script]
generic script-path=https://raw.githubusercontent.com/MaYIHEI/paperclip/refs/heads/testing/loon/ipquality/ipquality.js, tag=节点 IP 质量检测, timeout=50, img-url=shield.lefthalf.filled.system, argument="a={MaskIP}&b={MediaTest}&c={MapNotification}&d={ShowBasic}&e={ShowEgressMatrix}&f={ShowBGP}&g={ShowBGPPath}&h={ShowChinaHttp}&i={ShowInboundRoute}&j={ShowEnhancedRoute}&k={ShowTypes}&l={ShowRiskScores}&m={ShowRiskFactors}&n={ShowMedia}&o={ShowRegionConsistency}&p={ShowDataStatus}", enable=true
